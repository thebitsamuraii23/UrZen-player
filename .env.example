# ============================================
# Authentication Server Environment Variables
# ============================================

# Port the server will listen on (default: 3001)
PORT=3001

# JWT Secret key (MUST change in production!)
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-this-in-production

# Environment (development or production)
NODE_ENV=development

# ============================================
# Frontend Configuration (in index.html script)
# ============================================

# Backend API URL (for login/register requests)
# VITE_API_URL=http://localhost:3001

# Navidrome API URL (music server)
# VITE_NAVIDROME_URL=https://music.youtubemusicdownloader.life

# ============================================
# Optional: Third-party Services
# ============================================

# Sentry error tracking (optional)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Analytics (optional)
# ANALYTICS_KEY=your-analytics-key
