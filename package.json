{
  "name": "html-player-auth",
  "version": "1.0.0",
  "description": "HTML Music Player with Authentication",
  "main": "src/server.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/server.ts",
    "dev": "nodemon --watch src --watch index.html --watch css --watch assets --ext ts,html,css --exec \"tsx src/server.ts\""
  },
  "keywords": [
    "music",
    "player",
    "auth"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "nodemon": "^3.0.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
